<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>🏠 Smart Home Security Dashboard | IUEA Group 5</title>
    <script src="https://www.gstatic.com/firebasejs/9.x/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.x/firebase-database-compat.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0a0f1e 0%, #0f172a 100%);
            color: #e2e8f0;
            padding: 20px;
            min-height: 100vh;
        }
        
        .container {
            max-width: 1400px;
            margin: 0 auto;
        }
        
        h1 {
            text-align: center;
            margin-bottom: 10px;
            font-size: 2rem;
            background: linear-gradient(135deg, #60a5fa, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .subtitle {
            text-align: center;
            color: #94a3b8;
            margin-bottom: 30px;
            font-size: 0.9rem;
        }
        
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .card {
            background: rgba(30, 41, 59, 0.8);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 20px;
            border: 1px solid rgba(71, 85, 105, 0.5);
            transition: transform 0.2s, box-shadow 0.2s;
        }
        
        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3);
        }
        
        .card h3 {
            color: #94a3b8;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 15px;
            border-left: 3px solid #3b82f6;
            padding-left: 10px;
        }
        
        .status-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }
        
        .status-item {
            text-align: center;
            padding: 15px;
            background: rgba(15, 23, 42, 0.6);
            border-radius: 12px;
        }
        
        .status-label {
            font-size: 0.75rem;
            color: #94a3b8;
            margin-bottom: 5px;
        }
        
        .status-value {
            font-size: 1.5rem;
            font-weight: bold;
        }
        
        .status-value.motion-active { color: #ef4444; text-shadow: 0 0 10px rgba(239,68,68,0.5); }
        .status-value.motion-clear { color: #22c55e; }
        .status-value.alarm-active { color: #ef4444; animation: pulse 1s infinite; }
        .status-value.alarm-clear { color: #22c55e; }
        .status-value.door-unlocked { color: #22c55e; }
        .status-value.door-locked { color: #f59e0b; }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.6; }
        }
        
        .event-log {
            max-height: 300px;
            overflow-y: auto;
            font-family: 'Courier New', monospace;
            font-size: 0.8rem;
        }
        
        .event-entry {
            padding: 8px;
            border-bottom: 1px solid rgba(71, 85, 105, 0.3);
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }
        
        .event-time { color: #64748b; }
        .event-type { font-weight: bold; }
        .event-type.ALARM { color: #ef4444; }
        .event-type.ACCESS { color: #22c55e; }
        .event-type.SYSTEM { color: #3b82f6; }
        .event-detail { color: #cbd5e1; }
        
        .threat-gauge {
            width: 150px;
            height: 150px;
            margin: 0 auto;
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            text-align: center;
        }
        
        .stat-number {
            font-size: 2rem;
            font-weight: bold;
            color: #3b82f6;
        }
        
        .stat-label {
            font-size: 0.7rem;
            color: #94a3b8;
        }
        
        .footer {
            text-align: center;
            padding: 20px;
            color: #475569;
            font-size: 0.75rem;
        }
        
        canvas {
            max-height: 200px;
        }
        
        @media (max-width: 768px) {
            .dashboard-grid {
                grid-template-columns: 1fr;
            }
            .status-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🏠 SMART HOME SECURITY DASHBOARD</h1>
        <div class="subtitle">IUEA Group 5 | ESP32 | PIR | RFID | Firebase Real-time</div>
        
        <!-- Dashboard Grid -->
        <div class="dashboard-grid">
            <!-- Real-time Status Card -->
            <div class="card">
                <h3>📡 REAL-TIME STATUS</h3>
                <div class="status-grid">
                    <div class="status-item">
                        <div class="status-label">Motion Sensor</div>
                        <div class="status-value" id="motionValue">—</div>
                    </div>
                    <div class="status-item">
                        <div class="status-label">Alarm Status</div>
                        <div class="status-value" id="alarmValue">—</div>
                    </div>
                    <div class="status-item">
                        <div class="status-label">Door Lock</div>
                        <div class="status-value" id="doorValue">—</div>
                    </div>
                    <div class="status-item">
                        <div class="status-label">AI Threat</div>
                        <div class="status-value" id="threatValue">—</div>
                    </div>
                </div>
            </div>
            
            <!-- AI Threat Gauge Card -->
            <div class="card">
                <h3>🤖 AI THREAT ASSESSMENT</h3>
                <div class="threat-gauge">
                    <canvas id="threatGauge" width="150" height="150"></canvas>
                </div>
                <div style="text-align: center; margin-top: 15px;">
                    <span id="aiReason" style="font-size: 0.8rem; color: #94a3b8;">Waiting for data...</span>
                </div>
            </div>
            
            <!-- Statistics Card -->
            <div class="card">
                <h3>📊 SECURITY STATISTICS</h3>
                <div class="stats-grid">
                    <div>
                        <div class="stat-number" id="intrusionCount">0</div>
                        <div class="stat-label">Total Intrusions</div>
                    </div>
                    <div>
                        <div class="stat-number" id="accessCount">0</div>
                        <div class="stat-label">Authorized Access</div>
                    </div>
                    <div>
                        <div class="stat-number" id="eventCount">0</div>
                        <div class="stat-label">Total Events</div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Charts Row -->
        <div class="dashboard-grid">
            <div class="card">
                <h3>📈 ACTIVITY BY HOUR (AI Analysis)</h3>
                <canvas id="hourChart" width="400" height="200"></canvas>
            </div>
            <div class="card">
                <h3>🚨 EVENT TIMELINE</h3>
                <canvas id="timelineChart" width="400" height="200"></canvas>
            </div>
        </div>
        
        <!-- Event Log Card -->
        <div class="card">
            <h3>📋 LIVE EVENT LOG</h3>
            <div id="eventLog" class="event-log">
                <div style="text-align: center; color: #64748b;">Loading events...</div>
            </div>
        </div>
        
        <div class="footer">
            🔒 Data encrypted via Firebase | Last updated: <span id="lastUpdate">—</span>
        </div>
    </div>

    <script>
        // ============================================================
        // FIREBASE CONFIGURATION - YOUR PROJECT
        // ============================================================
        const firebaseConfig = {
            databaseURL: "https://smart-home-security-syst-2d94a-default-rtdb.europe-west1.firebasedatabase.app/"
        };
        
        // Initialize Firebase
        firebase.initializeApp(firebaseConfig);
        const database = firebase.database();
        
        // Chart instances
        let hourChart = null;
        let timelineChart = null;
        let threatGauge = null;
        
        // Data storage
        let allEvents = [];
        let hourData = {};
        
        // ============================================================
        // INITIALIZE GAUGE
        // ============================================================
        function initGauge() {
            const ctx = document.getElementById('threatGauge').getContext('2d');
            threatGauge = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    datasets: [{
                        data: [0, 100],
                        backgroundColor: ['#22c55e', '#1e293b'],
                        borderWidth: 0,
                        circumference: 180,
                        rotation: 270
                    }]
                },
                options: {
                    cutout: '70%',
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: { tooltip: { enabled: false }, legend: { display: false } }
                }
            });
        }
        
        // ============================================================
        // UPDATE GAUGE VALUE
        // ============================================================
        function updateGauge(value, reason) {
            if (!threatGauge) initGauge();
            const percentage = value * 100;
            threatGauge.data.datasets[0].data = [percentage, 100 - percentage];
            threatGauge.data.datasets[0].backgroundColor[0] = percentage > 50 ? '#ef4444' : '#22c55e';
            threatGauge.update();
            document.getElementById('aiReason').innerHTML = reason || 'Analyzing...';
        }
        
        // ============================================================
        // UPDATE STATUS DISPLAY
        // ============================================================
        function updateStatus(lastEvent) {
            if (!lastEvent) return;
            
            const motionDiv = document.getElementById('motionValue');
            const alarmDiv = document.getElementById('alarmValue');
            const doorDiv = document.getElementById('doorValue');
            const threatDiv = document.getElementById('threatValue');
            
            // Motion
            if (lastEvent.is_alarm === true) {
                motionDiv.innerHTML = '🚨 DETECTED';
                motionDiv.className = 'status-value motion-active';
                alarmDiv.innerHTML = '🔴 ACTIVE';
                alarmDiv.className = 'status-value alarm-active';
            } else {
                motionDiv.innerHTML = '✅ CLEAR';
                motionDiv.className = 'status-value motion-clear';
                alarmDiv.innerHTML = '🟢 OFF';
                alarmDiv.className = 'status-value alarm-clear';
            }
            
            // Door status (from servo angle)
            if (lastEvent.ai_reason && lastEvent.ai_reason.indexOf('Unlocked') >= 0) {
                doorDiv.innerHTML = '🔓 UNLOCKED';
                doorDiv.className = 'status-value door-unlocked';
            } else {
                doorDiv.innerHTML = '🔒 LOCKED';
                doorDiv.className = 'status-value door-locked';
            }
            
            // AI Threat
            if (lastEvent.is_suspicious === true) {
                threatDiv.innerHTML = '⚠️ SUSPICIOUS';
                threatDiv.style.color = '#ef4444';
            } else {
                threatDiv.innerHTML = '✅ NORMAL';
                threatDiv.style.color = '#22c55e';
            }
            
            // Update gauge
            if (lastEvent.ai_confidence !== undefined) {
                updateGauge(lastEvent.ai_confidence, lastEvent.ai_reason);
            }
        }
        
        // ============================================================
        // UPDATE STATISTICS
        // ============================================================
        function updateStats(events) {
            let intrusions = 0;
            let accesses = 0;
            
            events.forEach(event => {
                if (event.is_alarm === true) intrusions++;
                if (event.type === 'ACCESS') accesses++;
            });
            
            document.getElementById('intrusionCount').innerHTML = intrusions;
            document.getElementById('accessCount').innerHTML = accesses;
            document.getElementById('eventCount').innerHTML = events.length;
        }
        
        // ============================================================
        // UPDATE HOUR CHART
        // ============================================================
        function updateHourChart(events) {
            const hourCounts = new Array(24).fill(0);
            events.forEach(event => {
                if (event.hour !== undefined && event.hour >= 0 && event.hour < 24) {
                    hourCounts[event.hour]++;
                }
            });
            
            if (hourChart) hourChart.destroy();
            
            const ctx = document.getElementById('hourChart').getContext('2d');
            hourChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: Array.from({length: 24}, (_, i) => i + ':00'),
                    datasets: [{
                        label: 'Security Events',
                        data: hourCounts,
                        backgroundColor: (context) => {
                            const hour = context.dataIndex;
                            if (hour >= 22 || hour < 6) return '#ef4444';
                            return '#3b82f6';
                        },
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: { legend: { position: 'top' } },
                    scales: { y: { beginAtZero: true, grid: { color: '#1e293b' } } }
                }
            });
        }
        
        // ============================================================
        // UPDATE TIMELINE CHART
        // ============================================================
        function updateTimelineChart(events) {
            const last20 = events.slice(-20);
            const labels = last20.map(e => e.timestamp ? e.timestamp.split(' ')[1] : '?');
            const alarmData = last20.map(e => e.is_alarm === true ? 1 : 0);
            
            if (timelineChart) timelineChart.destroy();
            
            const ctx = document.getElementById('timelineChart').getContext('2d');
            timelineChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Alarm (1=Active, 0=Clear)',
                        data: alarmData,
                        borderColor: '#ef4444',
                        backgroundColor: 'rgba(239, 68, 68, 0.1)',
                        fill: true,
                        tension: 0.3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: { legend: { position: 'top' } },
                    scales: { y: { min: -0.1, max: 1.1, grid: { color: '#1e293b' } } }
                }
            });
        }
        
        // ============================================================
        // UPDATE EVENT LOG
        // ============================================================
        function updateEventLog(events) {
            const logDiv = document.getElementById('eventLog');
            if (events.length === 0) {
                logDiv.innerHTML = '<div style="text-align: center; color: #64748b;">No events yet. Trigger some in Wokwi!</div>';
                return;
            }
            
            let html = '';
            events.slice().reverse().slice(0, 20).forEach(event => {
                const time = event.timestamp ? event.timestamp.split(' ')[1] : '?';
                const typeClass = event.type === 'ALARM' ? 'ALARM' : (event.type === 'ACCESS' ? 'ACCESS' : 'SYSTEM');
                html += `
                    <div class="event-entry">
                        <span class="event-time">${time}</span>
                        <span class="event-type ${typeClass}">${event.type || 'UNKNOWN'}</span>
                        <span class="event-detail">${event.detail || event.ai_reason || '—'}</span>
                        <span>${event.is_suspicious ? '🚨' : '✅'}</span>
                    </div>
                `;
            });
            logDiv.innerHTML = html;
            document.getElementById('lastUpdate').innerHTML = new Date().toLocaleTimeString();
        }
        
        // ============================================================
        // FETCH AND RENDER ALL DATA
        // ============================================================
        function loadData() {
            const eventsRef = database.ref('/events');
            eventsRef.on('value', (snapshot) => {
                const data = snapshot.val();
                if (!data) {
                    console.log('No events found');
                    return;
                }
                
                const events = Object.values(data);
                allEvents = events;
                
                // Sort by epoch if available
                events.sort((a, b) => (a.epoch || 0) - (b.epoch || 0));
                
                // Get latest event
                const latestEvent = events[events.length - 1];
                
                // Update all UI components
                updateStatus(latestEvent);
                updateStats(events);
                updateHourChart(events);
                updateTimelineChart(events);
                updateEventLog(events);
                
                // Update counters from latest event if available
                if (latestEvent) {
                    if (latestEvent.intrusionCount !== undefined) {
                        document.getElementById('intrusionCount').innerHTML = latestEvent.intrusionCount;
                    }
                    if (latestEvent.accessCount !== undefined) {
                        document.getElementById('accessCount').innerHTML = latestEvent.accessCount;
                    }
                }
                
                console.log(`Loaded ${events.length} events`);
            }, (error) => {
                console.error('Firebase error:', error);
                document.getElementById('eventLog').innerHTML = '<div style="text-align: center; color: #ef4444;">❌ Firebase connection error. Check your database rules.</div>';
            });
        }
        
        // ============================================================
        // INITIALIZE
        // ============================================================
        document.addEventListener('DOMContentLoaded', () => {
            initGauge();
            loadData();
        });
    </script>
</body>
</html>